GLYPHHOLD_URL=https://glyphhold.example.com
GLYPHHOLD_API_KEY=gh_live_xxxxxxxxxxxxxxxxx

# Optional TLS settings.
# Prefer GLYPHHOLD_CA_BUNDLE for private/internal certificate authorities.
# Use GLYPHHOLD_VERIFY_SSL=false only for trusted internal test deployments.
# GLYPHHOLD_CA_BUNDLE=/path/to/ca-bundle.pem
# GLYPHHOLD_VERIFY_SSL=true
